generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  logoUrl   String?
  address   String?
  phone     String?
  mode      AppMode  @default(KID)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buses       Bus[]
  students    Student[]
  users       User[]
  assets      Asset[]
  parents     Parent[]
  clients     Client[]
  agents      Agent[]
  panicEvents PanicEvent[]
  AgentTenant AgentTenant[]

  @@index([mode])
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String
  phone    String?
  role     Role
  password String

  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parent Parent? @relation("UserToParent")
  client Client? @relation("UserToClient")
  agent  Agent?  @relation("UserToAgent")

  resetOtp          String?
  resetOtpExpiresAt DateTime?
  resetOtpSentAt    DateTime?

  driverBuses        Bus[]      @relation("DriverBus")
  assistantBuses     Bus[]      @relation("AssistantBus")
  assistantManifests Manifest[] @relation("AssistantManifest")

  student     Student?     @relation("UserStudent")
  panicEvents PanicEvent[] @relation("UserToPanicEvents")

  deliveredAssets Asset[] @relation("AssetDeliveredBy")
  confirmedAssets Asset[] @relation("AssetConfirmedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([phone, tenantId])
  @@index([tenantId])
  @@index([role])
}

model Parent {
  id       Int  @id @default(autoincrement())
  tenantId Int
  userId   Int? @unique

  user   User?  @relation("UserToParent", fields: [userId], references: [id], onDelete: SetNull)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  students      Student[]
  notifications Notification[]

  wallet        Wallet?
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[] @relation("ParentTransactions")

  @@index([tenantId])
}

model Client {
  id       Int  @id @default(autoincrement())
  tenantId Int
  userId   Int? @unique

  user   User?  @relation("UserToClient", fields: [userId], references: [id], onDelete: SetNull)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assets        Asset[]
  notifications Notification[]

  wallet        Wallet?
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[] @relation("ClientTransactions")

  @@index([tenantId])
}

model Bus {
  id          Int      @id @default(autoincrement())
  name        String
  plateNumber String
  capacity    Int
  route       String
  driverId    Int?
  assistantId Int?
  createdAt   DateTime @default(now())

  tenantId  Int
  updatedAt DateTime @updatedAt

  assistant User? @relation("AssistantBus", fields: [assistantId], references: [id], onDelete: SetNull)
  driver    User? @relation("DriverBus", fields: [driverId], references: [id], onDelete: SetNull)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locations     BusLocation[]
  liveLocations LiveLocation[]
  manifests     Manifest[]
  students      Student[]
  assets        Asset[]

  @@unique([tenantId, plateNumber])
  @@index([tenantId])
}

model Student {
  id        Int    @id @default(autoincrement())
  name      String
  grade     String
  latitude  Float
  longitude Float

  busId    Int
  parentId Int?
  tenantId Int
  userId   Int? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bus    Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parent Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)
  user   User?   @relation("UserStudent", fields: [userId], references: [id], onDelete: SetNull)

  manifests   Manifest[]
  panicEvents PanicEvent[]

  // 🔥 Monetization
  subscriptions Subscription[]

  @@index([tenantId])
  @@index([busId])
  @@index([parentId])
}

model Asset {
  id   Int     @id @default(autoincrement())
  name String
  type String?
  tag  String?

  busId    Int?
  clientId Int?
  tenantId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryStatus AssetDeliveryStatus @default(IN_TRANSIT)
  deliveredAt    DateTime?
  confirmedAt    DateTime?

  deliveredByUserId Int?
  deliveredByUser   User? @relation("AssetDeliveredBy", fields: [deliveredByUserId], references: [id], onDelete: SetNull)

  confirmedById Int?
  confirmedBy   User? @relation("AssetConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bus    Bus?    @relation(fields: [busId], references: [id], onDelete: SetNull)

  manifests   Manifest[]
  panicEvents PanicEvent[]

  // 🔥 Monetization
  subscriptions Subscription[]

  @@index([tenantId])
  @@index([busId])
  @@index([clientId])
}

model Manifest {
  id          Int  @id @default(autoincrement())
  studentId   Int?
  assetId     Int?
  busId       Int
  assistantId Int?

  date          DateTime  @default(now())
  latitude      Float?
  longitude     Float?
  boardingTime  DateTime?
  alightingTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status  ManifestStatus
  session ManifestSession @default(MORNING)

  assistant User?    @relation("AssistantManifest", fields: [assistantId], references: [id], onDelete: SetNull)
  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([assetId])
  @@index([busId, createdAt])
  @@index([studentId, createdAt])
}

model Notification {
  id       Int  @id @default(autoincrement())
  parentId Int?
  clientId Int?

  title   String
  message String
  type    String

  sentAt DateTime @default(now())
  read   Boolean  @default(false)

  parent Parent? @relation(fields: [parentId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([clientId])
}

model BusLocation {
  id       Int @id @default(autoincrement())
  busId    Int
  deviceId Int

  lat       Float
  lng       Float
  direction Int?
  speed     Float?
  state     String?
  movement  String?

  lastUpdate DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bus Bus @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId, lastUpdate])
}

model LiveLocation {
  id         Int    @id @default(autoincrement())
  vehicleReg String @unique
  busId      Int?

  lat           Float
  lng           Float
  direction     Float
  speed         Float?
  movementState String?

  lastUpdate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bus Bus? @relation(fields: [busId], references: [id], onDelete: SetNull)

  @@index([busId])
  @@index([lastUpdate])
  @@index([vehicleReg])
}

model PanicEvent {
  id       Int  @id @default(autoincrement())
  userId   Int
  childId  Int?
  assetId  Int?
  tenantId Int

  latitude    Float
  longitude   Float
  phoneNumber String?
  role        Role
  ipAddress   String?
  userAgent   String?
  status      PanicStatus
  createdAt   DateTime    @default(now())
  createdBy   String

  user   User     @relation("UserToPanicEvents", fields: [userId], references: [id], onDelete: Cascade)
  child  Student? @relation(fields: [childId], references: [id], onDelete: SetNull)
  asset  Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([childId])
  @@index([assetId])
  @@index([tenantId])
}

enum AgentTxType {
  COMMISSION
  WITHDRAWAL
  TOPUP
  ADJUSTMENT
}

//////////////////////////////////////////////////////
// 🤝 AGENT SYSTEM
//////////////////////////////////////////////////////

model Agent {
  id             Int     @id @default(autoincrement())
  userId         Int     @unique
  commissionRate Float   @default(0.10)
  isActive       Boolean @default(true)

  user    User          @relation("UserToAgent", fields: [userId], references: [id], onDelete: Cascade)
  wallet  AgentWallet?
  tenants AgentTenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId  Int?

  @@index([userId])
}

model AgentWallet {
  id      Int   @id @default(autoincrement())
  agentId Int   @unique
  balance Float @default(0)

  agent        Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  transactions AgentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
}

model AgentTransaction {
  id          Int         @id @default(autoincrement())
  walletId    Int
  type        AgentTxType
  amount      Float
  reference   String?     @unique
  description String?

  balanceBefore Float
  balanceAfter  Float

  wallet AgentWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model AgentTenant {
  id       Int @id @default(autoincrement())
  agentId  Int
  tenantId Int

  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  onboardedAt DateTime @default(now())

  @@unique([agentId, tenantId])
  @@index([agentId])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// 💰 MONETIZATION MODELS
//////////////////////////////////////////////////////

model Wallet {
  id       Int  @id @default(autoincrement())
  parentId Int? @unique
  clientId Int? @unique

  balance Float @default(0)

  parent Parent? @relation(fields: [parentId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  transactions Transaction[] @relation("WalletTransactions")
  ledger       Ledger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([clientId])
}

model Subscription {
  id        Int  @id @default(autoincrement())
  parentId  Int?
  clientId  Int?
  studentId Int?
  assetId   Int?

  type       SubscriptionType   @default(DAILY)
  status     SubscriptionStatus @default(ACTIVE)
  expiryDate DateTime

  parent  Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  asset   Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, studentId])
  @@unique([clientId, assetId])
  @@index([expiryDate])
}

model Transaction {
  id Int @id @default(autoincrement())

  parentId Int?
  clientId Int?
  walletId Int

  amount    Float
  type      TransactionType
  status    TransactionStatus @default(SUCCESS)
  reference String?           @unique

  wallet Wallet @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)

  parent Parent? @relation("ParentTransactions", fields: [parentId], references: [id], onDelete: Cascade)
  client Client? @relation("ClientTransactions", fields: [clientId], references: [id], onDelete: Cascade)

  ledger Ledger[]

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([parentId])
  @@index([clientId])
  @@index([type, status])
  @@index([createdAt])
}

model Ledger {
  id Int @id @default(autoincrement())

  walletId Int
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type   LedgerType
  amount Float

  balanceBefore Float
  balanceAfter  Float

  reference   String? @unique
  description String?

  transactionId Int?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([transactionId])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SYSTEM_ADMIN
  AGENT
  ADMIN
  DRIVER
  ASSISTANT
  PARENT
  CLIENT
  MERCHANT
}

enum ManifestStatus {
  CHECKED_IN
  CHECKED_OUT
}

enum ManifestSession {
  MORNING
  EVENING
}

enum PanicStatus {
  ACTIVE
  PENDING
  ACKNOWLEDGED
  RESOLVED
  CONFIRMED
}

enum AppMode {
  KID
  ASSET
}

enum AssetDeliveryStatus {
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  CANCELLED
}

enum SubscriptionType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  DEDUCTION
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum LedgerType {
  CREDIT
  DEBIT
}
